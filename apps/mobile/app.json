{
  "expo": {
    "name": "MasterAI Casting",
    "slug": "masterai-casting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "masterai-casting",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#07070d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.masterai.casting"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07070d"
      },
      "package": "com.masterai.casting"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"]
  }
}
